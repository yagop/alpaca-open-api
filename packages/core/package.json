{
  "name": "@alpaca-open-api/core",
  "version": "0.1.0",
  "description": "Typed fetch clients and types for the Alpaca Markets API, generated from the official OpenAPI specifications with Orval",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.js --target node --format esm && tsc -p tsconfig.build.json && bun scripts/fix-dts-extensions.ts && tsc -p tsconfig.dts-check.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "alpaca",
    "alpaca-markets",
    "trading",
    "api",
    "typescript",
    "openapi"
  ],
  "author": "Yago",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yagop/alpaca-api-ts.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/yagop/alpaca-api-ts#readme",
  "bugs": "https://github.com/yagop/alpaca-api-ts/issues",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
