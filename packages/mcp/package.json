{
  "name": "@alpaca-open-api/mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for the Alpaca Markets API — exposes all Trading, Market Data, Broker, and AuthX endpoints to AI agents",
  "type": "module",
  "bin": {
    "alpaca-mcp": "dist/mcp.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/mcp.ts --outfile dist/mcp.js --target node --conditions source --external @modelcontextprotocol/sdk --external zod",
    "start": "bun run src/mcp.ts",
    "dev": "bun run --watch src/mcp.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "alpaca",
    "alpaca-markets",
    "trading",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent"
  ],
  "author": "Yago",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yagop/alpaca-open-api.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/yagop/alpaca-open-api#readme",
  "bugs": "https://github.com/yagop/alpaca-open-api/issues",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@alpaca-open-api/core": "1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
