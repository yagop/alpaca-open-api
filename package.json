{
  "name": "alpaca-open-api",
  "version": "1.0.1",
  "private": true,
  "description": "Monorepo for the Open Alpaca API TypeScript client and MCP server",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate": "bunx --bun orval --config orval.config.ts && bun packages/mcp/scripts/postgen.ts",
    "build": "bun run generate && bun run --filter '@alpaca-open-api/*' build",
    "mcp": "bun run --filter '@alpaca-open-api/mcp' start",
    "test": "bun test"
  },
  "keywords": [
    "alpaca",
    "alpaca-markets",
    "trading",
    "api",
    "typescript",
    "openapi",
    "mcp",
    "bun"
  ],
  "author": "Yago",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "orval": "^8.18.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
