{
  "name": "open-alpaca-api",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the Open Alpaca API TypeScript client and MCP server",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate": "bun run --filter '@open-alpaca-api/core' generate",
    "build": "bun run --filter '@open-alpaca-api/core' build && bun run --filter '@open-alpaca-api/mcp' build",
    "mcp": "bun run --filter '@open-alpaca-api/mcp' start"
  },
  "keywords": [
    "alpaca",
    "alpaca-markets",
    "trading",
    "api",
    "typescript",
    "openapi",
    "mcp",
    "bun"
  ],
  "author": "Yago",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
