# Alpaca API Credentials
# Get your API keys from: https://alpaca.markets/

ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Environment: paper (default, recommended for testing) or live
# Paper: https://paper-api.alpaca.markets
# Live:  https://api.alpaca.markets
ALPACA_ENV=paper

# Optional: restrict the MCP server to a subset of APIs (comma-separated).
# One or more of: trading,data,broker,authx. Defaults to all four.
# ALPACA_MCP_APIS=trading,data
